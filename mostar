fi
if ! [[ "$GSIZE" =~ ^[0-9]+(\.[0-9]+)?[kKmMgG]?$ ]]; then
    echo "[ERROR] Invalid genome size format: $GSIZE"; exit 1
fi

# Required tools
for tool in flye medaka_consensus samtools bwa amrfinder; do
