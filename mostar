# Defaults
THREADS=10
MEDAKA_MODEL="r1041_e82_400bps_sup_v5.2.0"
FILTLONG_COV=100
BAKTA_MIN_CONTIG_LEN=200
BAKTA_DB=""
BAKTA_COMPLETE=""
BAKTA_REGIONS=""
BAKTA_SUCCESS=false
R1=""
R2=""
ONT=""
ORGANISM=""
EMU_DB=""
OUTDIR=""
GSIZE=""
CLEANUP=false
RUN_KRAKEN2=false
KRAKEN2_DB=""
KRAKEN_CONFIDENCE="0.1"
USE_META=""

# Options and arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--ont)           ONT="$2"; shift 2 ;;
        -1|--r1)            R1="$2"; shift 2 ;;  
        -2|--r2)            R2="$2"; shift 2 ;;  
        -a|--bakta_ref)     BAKTA_REGIONS="$2"; shift 2 ;;
        -g|--genome-size)   GSIZE="$2"; shift 2 ;;
        -o|--output)        OUTDIR="$2"; shift 2 ;;
        -b|--bakta-db)      BAKTA_DB="$2"; shift 2 ;;
        -k|--kraken-db)     KRAKEN2_DB="$2"; RUN_KRAKEN2=true; shift 2 ;;
        -c|--confidence)    KRAKEN_CONFIDENCE="$2"; shift 2 ;;
        -m|--model)        MEDAKA_MODEL="$2"; shift 2 ;;
        -p|--organism)      ORGANISM="$2"; shift 2 ;;
        -e|--emu-db)        EMU_DB="$2"; shift 2 ;;
        -t|--threads)       THREADS="$2"; shift 2 ;;
        -f|--filtlong-cov)  FILTLONG_COV="$2"; shift 2 ;;
        -i|--complete)      BAKTA_COMPLETE="--complete"; shift 1 ;;
        -M|--meta)          USE_META=--meta; shift 1 ;;
        -x|--cleanup)       CLEANUP=true; shift 1 ;;
        -h|--help)          usage ;;
        *) echo "[ERROR] Unknown argument: $1"; usage ;;
    esac
done

MISSING_ARGS=0

# Check if input files exist and are valid
if [[ -z "$ONT" ]]; then
    echo "[ERROR] No input file specified (--ont)."
    MISSING_ARGS=1
elif [[ ! -f "$ONT" ]]; then
    echo "[ERROR] Input-file not found: $ONT"
    MISSING_ARGS=1
fi

# Check wether user needs to provide genome size or not
if [[ -z "$GSIZE" ]]; then
    echo "[ERROR] Genome size (-g) is mandatory (e.g., -g 5.4m)."
    exit 1
fi

if [[ -z "$ONT" || ! -f "$ONT" ]]; then
    echo "[ERROR] Valid ONT input file (--ont) is required."
    exit 1
fi

# Check for missing tools
for tool in flye medaka_consensus samtools bwa amrfinder; do
    if ! command -v "$tool" &> /dev/null; then
        echo "[ERROR] Verktøyet '$tool' er ikke installert eller finnes ikke i PATH."
        MISSING_ARGS=1
    fi
done

# Output directory setup
if [[ -z "$OUTDIR" ]]; then
    OUTDIR="MOSTAR_$(date +%Y%m%d_%H%M%S)"
    echo "[WARNING] Output directory not set, using: $OUTDIR"
fi
mkdir -p "$OUTDIR/logs" "$OUTDIR/intermediate" "$OUTDIR/amr_results"

# Check for BAKTA database
SKIP_BAKTA=false
if [[ -z "$BAKTA_DB" || ! -d "$BAKTA_DB" ]]; then
    echo "[WARNING] Bakta database is missing or not specified. Skipping annotation."
    SKIP_BAKTA=true
fi

# Check for Kraken2 database
if [[ -z "$KRAKEN2_DB" || ! -d "$KRAKEN2_DB" ]]; then
    echo "[INFO] Kraken2 database not found. Skipping taxonomy analysis."
    RUN_KRAKEN2=false
fi

# Fallbacks for optional parameters
[[ -z "$BAKTA_MIN_CONTIG_LEN" ]] && BAKTA_MIN_CONTIG_LEN=200
[[ -z "$THREADS" ]] && THREADS=4

# Stop if any critical arguments are missing
if [[ $MISSING_ARGS -eq 1 ]]; then
    echo "--------------------------------------------------------------------------------"
    echo "Pipeline is missing required arguments or tools. Please review the errors above."
    echo "Hint: run mostar -h for usage instructions."
    exit 1
fi
    echo ""
    echo ""
    echo ""
    echo "              __      __   __    ____  _______   __     _____             "
    echo "              | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "              | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "              |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""
    echo version $VERSION 

# ==============================================================================
#                           Genome Size sanity check
# ==============================================================================

if ! [[ "$GSIZE" =~ ^[0-9]+(\.[0-9]+)?[kKmMgG]?$ ]]; then
    echo "[ERROR] Invalid genome size format: $GSIZE"
    exit 1
fi

# ==============================================================================
#                                   Init
# ==============================================================================
# Validate required args
if [[ -z "$OUTDIR" ]]; then
    echo "[ERROR] Output directory (-o) not provided" >&2
    exit 1
fi

if [[ -z "$ONT" ]]; then
