<body>
    <div class="card" style="background:var(--primary); color:white;">
        <h1 style="margin:0;">MOSTAR Run Report</h1>
        <p style="margin:5px 0 0 0;"><b>Sample:</b> $REPORT_SAMPLE | <b>Date:</b> $REPORT_DATE | <b>Run Time:</b> $DURATION min</p>
    </div>

    <div class="qc-row">
        $TAX_CARDS
        $HYBRID_CARDS
    </div>

    <div class="card">
        <h2>Assembly Metrics Comparison</h2>
        <table>
            <thead>
                <tr>
                    <th style="width: 40%;">Metric</th>
                    <th style="color: #7f8c8d;">Medaka (ONT Only)</th>
