EOF

    echo "[MOSTAR] HTML report written to: $HTML_OUT"
}

# Defaults
THREADS=10
MEDAKA_MODEL="r1041_e82_400bps_sup_v5.2.0"
FILTLONG_COV=100
PROKKA_COV=80
PROKKA_EVAL="1e-09"
R1=""
R2=""
ONT=""
PROT_REF=""
ORGANISM=""
EMU_DB=""
OUTDIR=""
GSIZE=""
CLEANUP=false
PROKKA_SUCCESS=false

# Options and arguments
while getopts "1:2:n:g:o:a:t:m:c:i:f:p:k:xh" opt; do
    case ${opt} in
        1) R1=$OPTARG ;;
        2) R2=$OPTARG ;;
        n) ONT=$OPTARG ;;
        g) GSIZE=$OPTARG ;;
        o) OUTDIR=$OPTARG ;;
        a) PROT_REF=$OPTARG ;;
        t) THREADS=$OPTARG ;;
        c) PROKKA_COV=$OPTARG ;;
        i) PROKKA_EVAL=$OPTARG ;;
        m) MEDAKA_MODEL=$OPTARG ;;
        p) ORGANISM=$OPTARG ;;
        k) EMU_DB=$OPTARG ;;
        f) FILTLONG_COV=$OPTARG ;;
        x) CLEANUP=true ;;
        h) usage ;;
        *) usage ;;
    esac
done

MISSING_ARGS=0

if [[ -z "${ONT:-}" ]]; then
    echo "[ERROR] Missing ONT reads (-n). Please provide your .fastq.gz file."
    MISSING_ARGS=1
fi

if [[ -z "${GSIZE:-}" ]]; then
    echo "[ERROR] Missing Genome Size (-g). Example: -g 2.1m"
    MISSING_ARGS=1
fi

if [[ -z "${OUTDIR:-}" ]]; then
    echo "[ERROR] Missing Output Directory (-o). Where should I save the results?"
    MISSING_ARGS=1
fi

# If any required arg is missing, show a tiny hint and exit
if [[ $MISSING_ARGS -eq 1 ]]; then
    echo ""
    echo "Hint: mostar -n [reads.fq.gz] -g [size] -o [output_dir]"
    echo "Run 'mostar -h' for full list of commands help."
    exit 1
fi

    echo ""
    echo ""
    echo "              __      __   __    ____  _______   __     _____             "
    echo "              | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "              | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "              |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""
    echo version $VERSION 

# ==============================================================================
#                           Genome Size sanity check
# ==============================================================================

if ! [[ "$GSIZE" =~ ^[0-9]+(\.[0-9]+)?[kKmMgG]?$ ]]; then
    echo "[ERROR] Invalid genome size format: $GSIZE"
    exit 1
fi

# ==============================================================================
#                                   Init
# ==============================================================================
# Validate required args
if [[ -z "$OUTDIR" ]]; then
    echo "[ERROR] Output directory (-o) not provided" >&2
    exit 1
fi

if [[ -z "$ONT" ]]; then
    echo "[ERROR] ONT reads (-n) not provided" >&2
    exit 1
fi

if [[ ! -s "$ONT" ]]; then
    echo "[ERROR] ONT reads file missing or empty: $ONT" >&2
    exit 1
fi

# Create directories BEFORE use
mkdir -p \
    "$OUTDIR" \
    "$OUTDIR/intermediate" \
    "$OUTDIR/logs" \

mkdir -p "$OUTDIR"/{intermediate,logs,amr_results}
REAL_OUT=$(cd "$OUTDIR" && pwd)
FINAL_ASM="$REAL_OUT/MOSTAR_Assembly.fasta"

MODE_LABEL=$([[ -n "$R1" && -n "$R2" ]] && echo "Hybrid Mode" || echo "ONT-only Mode")


# ==============================================================================
#                               Assembly stats
# ==============================================================================


calc_assembly_stats() {
    awk '/^>/ {if (l){print l}; l=0; next} {l+=length($0)} END {print l}' "$1" | \
    sort -rn | \
    awk '{a[i++]=$1; s+=$1}
         END {
            if(s==0 || i==0){print "0 0 0 0"; exit}
            for(j=0;j<i;j++){
                t+=a[j];
                if(t>=s/2){print s, i, a[j], j+1; break}
            }
         }'
}

if [[ -n "$R1" && -n "$R2" ]]; then
    echo ""
    echo "=============================================================================="
    echo "[$(date +%T)] Performing Short-read filtering (FastP)"
    echo "=============================================================================="
    
    fastp \
        --in1 "$R1" --in2 "$R2" \
        --out1 "$OUTDIR/intermediate/sh_R1.fq.gz" \
        --out2 "$OUTDIR/intermediate/sh_R2.fq.gz" \
        --thread "$THREADS" \
        --json "$OUTDIR/logs/fastp.json" \
        --html "$OUTDIR/logs/fastp.html" \
        > "$OUTDIR/logs/fastp.stdout" 2> "$OUTDIR/logs/fastp.stderr"
        echo "[$(date +%T)] FastP short-read filtering completed"
        echo "[$(date +%T)] FastP log: $OUTDIR/logs/fastp.html"
else
    echo "=============================================================================="
    echo "[$(date +%T)] Skipping FastP: No short-reads provided (ONT-only mode)"
    echo "=============================================================================="
fi


echo ""
echo ""
echo "=============================================================================="
echo "[$(date +%T)] Performing Long-read filtering using Filtlong"
echo "=============================================================================="
# Automatic filtlong calculation 100x
NUM=$(echo "$GSIZE" | tr -d '[:alpha:]')
UNIT=$(echo "$GSIZE" | tr -d '0-9.')
TARGET_BASES=$(echo "$NUM" | awk '{print $1 * 100}')$UNIT

if [[ -n "${R1:-}" ]]; then
    filtlong --min_length 1000 --keep_percent 90 --target_bases "$TARGET_BASES" \
             -1 "$OUTDIR/intermediate/sh_R1.fq.gz" \
             -2 "$OUTDIR/intermediate/sh_R2.fq.gz" \
             "$ONT" > "$OUTDIR/intermediate/ont_filt.fq" 2> "$OUTDIR/logs/filtlong.log"
else
    filtlong --min_length 1000 --keep_percent 90 --target_bases "$TARGET_BASES" \
             "$ONT" > "$OUTDIR/intermediate/ont_filt.fq" 2> "$OUTDIR/logs/filtlong.log"
fi

gzip -f "$OUTDIR/intermediate/ont_filt.fq"

FILTERED_READ_COUNT=$(tail -n 1 "$OUTDIR/logs/filtlong.log" | awk '{print $1$2$3}' | tr -cd '0-9' || echo "0")

echo "[$(date +%T)] Filtlong filtering completed"
echo "[$(date +%T)] Filtlong log: $OUTDIR/logs/filtlong.log"
echo ""
echo ""

# Taxonomic classification with EMU [Optional]
TOP_TAXID="N/A"
TOP_CONF="0.00"
TOP_ABUNDANCE="0.00"
TOP_SPECIES="Unknown"

if [[ -n "${EMU_DB:-}" ]]; then
    EMU_FASTA="$EMU_DB/species_taxid.fasta"
    EMU_TAX="$EMU_DB/taxonomy.tsv"

    # Install EMU database if not present (Requires osfclient and access to the OSF project)
    if [[ ! -f "$EMU_FASTA" ]]; then
        echo "[$(date +%T)] EMU database missing. Automatic download starting..."
        
        # Check if osfclient is installed
        if ! command -v osf &>/dev/null; then
            echo "[ERROR] osfclient is not installed. Please run: pip install osfclient"
            exit 1
        fi

        mkdir -p "$EMU_DB"
        (
            cd "$EMU_DB"
            osf -p 56uf7 fetch osfstorage/emu-prebuilt/emu.tar
            tar -xvf emu.tar
        )
    fi

    # Run EMU
    if [[ -f "$EMU_FASTA" ]]; then
        echo "=============================================================================="
        echo "[$(date +%T)] Running Taxonomic classification with EMU"
        echo "=============================================================================="   
        mkdir -p "$OUTDIR/taxonomy"
        emu abundance "$OUTDIR/intermediate/ont_filt.fq.gz" \
                      --db "$EMU_DB" \
                      --threads "$THREADS" \
                      --output-dir "$OUTDIR/taxonomy" \
                      --output-basename emu_results > /dev/null 2>&1

        # Get results
        EMU_REPORT=$(ls "$OUTDIR/taxonomy/"*rel-abundance.tsv 2>/dev/null | grep -v "species" | head -n 1)
        if [[ -n "$EMU_REPORT" && -s "$EMU_REPORT" ]]; then
        TOP_TAXID=$(awk -F'\t' 'NR==2 {print $1}' "$EMU_REPORT")
        TOP_ABUNDANCE=$(LC_NUMERIC=C awk -F'\t' 'NR==2 {printf "%.2f", $2*100}' "$EMU_REPORT")
        else
        TOP_TAXID="N/A"
        TOP_ABUNDANCE="0.00"
        fi
    fi
