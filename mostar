    <!-- Software Environment -->
    <div class="card">
        <h2>Software Environment</h2>
        <div class="software-grid">
            <div class="soft-item"><b>Flye</b>${VER_FLYE}</div>
            <div class="soft-item"><b>EMU</b>${VER_EMU}</div>
            <div class="soft-item"><b>Polypolish</b>${VER_POLY}</div>
            <div class="soft-item"><b>AMRFinder+</b>${VER_AMR}</div>
            <div class="soft-item"><b>BWA</b>${VER_BWA}</div>
            <div class="soft-item"><b>Medaka</b>${VER_MEDAKA}</div>
            <div class="soft-item"><b>Filtlong</b>${VER_FILT}</div>
            <div class="soft-item"><b>Prokka</b>${VER_PROKKA}</div>
            <div class="soft-item"><b>FastP</b>${VER_FASTP}</div>
            <div class="soft-item"><b>Samtools</b>${VER_SAM}</div>
            <div class="soft-item"><b>MOSTAR</b>v${VERSION}</div>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">MOSTAR v${VERSION} &nbsp;|&nbsp; Nermin Zecic, 2026</div>

</div><!-- /.wrapper -->
</body>
