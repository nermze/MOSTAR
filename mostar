    echo ""
    echo "=============================================================================="
    echo "[$(date +%T)] Performing Long-read filtering using Polypolish"
    echo "=============================================================================="
    # Polypolish requires separate SAMs for R1 and R2 
    bwa index "$OUTDIR/medaka/consensus.fasta" > "$OUTDIR/logs/bwa_index.log" 2>&1

    bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R1.fq.gz" > "$OUTDIR/intermediate/1.sam" 2> "$OUTDIR/logs/bwa_r1.log"
    bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R2.fq.gz" > "$OUTDIR/intermediate/2.sam" 2> "$OUTDIR/logs/bwa_r2.log"

    samtools flagstat "$OUTDIR/intermediate/1.sam" > "$OUTDIR/logs/bwa_flagstat.txt" 2>&1
    BWA_MAPPING_RATE=$(awk -F'[()]' '/mapped/{print $2}' "$OUTDIR/logs/bwa_flagstat.txt" | head -n1 | tr -d '%')

    polypolish filter \
        --in1 "$OUTDIR/intermediate/1.sam" \
        --in2 "$OUTDIR/intermediate/2.sam" \
        --out1 "$OUTDIR/intermediate/f1.sam" \
        --out2 "$OUTDIR/intermediate/f2.sam" \
        > /dev/null 2> "$OUTDIR/logs/polypolish_filter.log"

    polypolish polish \
        "$OUTDIR/medaka/consensus.fasta" \
        "$OUTDIR/intermediate/f1.sam" \
        "$OUTDIR/intermediate/f2.sam" \
        > "$FINAL_ASM" 2> "$OUTDIR/logs/polypolish.log"
    

    MEAN_DEPTH=$(grep "mean read depth" "$OUTDIR/logs/polypolish.log" | awk '{print $4}')
    POS_CHANGED=$(grep "positions changed" "$OUTDIR/logs/polypolish.log" | awk '{print $1}' | tr -d ',')
    ZERO_DEPTH_BP=$(grep "depth of zero" "$OUTDIR/logs/polypolish.log" | awk '{print $1}' | tr -d ',')
    read F_LEN F_CNT F_N50 F_L50 <<< "$(calc_assembly_stats "$FINAL_ASM")"
    export FINAL_LEN="$F_LEN"
    export FINAL_CNT="$F_CNT"
    export FINAL_N50="$F_N50"
    export MEAN_DEPTH POS_CHANGED ZERO_DEPTH_BP

else
