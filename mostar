echo "=============================================================================="
echo "[$(date +%T)] De-novo assembly with Flye, this might take while..."
echo "=============================================================================="

echo "[$(date +%T)] Starting assembly with genome size: $GSIZE" 

flye --nano-hq "$OUTDIR/intermediate/ont_filt.fq.gz" \
     --genome-size "$GSIZE" \
     --threads "$THREADS" \
     $USE_META \
     --out-dir "$OUTDIR/flye" > "$OUTDIR/logs/flye.log" 2>&1

echo "[$(date +%T)] Flye assembly completed!"
echo "[$(date +%T)] Flye log: $OUTDIR/logs/flye.log"
echo "[$(date +%T)] Flye assembly results: $OUTDIR/flye/assembly.fasta"

# Polishing and error-correction with Medaka
