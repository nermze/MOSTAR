amrfinder --database_version >/dev/null 2>&1 || amrfinder -u

AMR_CMD=(amrfinder --threads "$THREADS" --plus -n "$FINAL_ASM")
[[ -n "$ORGANISM" ]] && AMR_CMD+=(-O "$ORGANISM")

if [[ "$PROKKA_SUCCESS" == true ]]; then
    AMR_CMD+=(-p "$OUTDIR/annotation/mostar_Annotation.faa" -g "$OUTDIR/annotation/mostar_Annotation.gff")
fi

"${AMR_CMD[@]}" > "$OUTDIR/amr_results/AMR_Report.tsv"


# Cleanup intermediate files if the flag is set
if [[ "$CLEANUP" == true ]]; then
