    </div>
    <div class="card" style="font-size:0.78rem;">
        <h2>Resistance Profile (AMRFinder+)</h2>
        <table>
            <colgroup>
                <col style="width:20%">
                <col style="width:45%">
                <col style="width:35%">
            </colgroup>
            <thead>
