    body { font-family: sans-serif; background: var(--bg); color: var(--primary); padding: 30px; line-height: 1.6; }
    .card { background: white; padding: 25px; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 25px; }
    .qc-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin-bottom: 25px; }
    .qc-card { background: white; padding: 15px; border-radius: 12px; border: 1px solid var(--border); text-align: center; }
    .qc-label { display: block; font-size: 0.7rem; color: #7f8c8d; text-transform: uppercase; margin-bottom: 5px; font-weight: 600; }
    .qc-val { font-weight: 700; font-size: 1.1rem; }
    table { width: 100%; border-collapse: collapse; }
    th { padding: 12px 0; border-bottom: 2px solid var(--border); text-align: left; font-size: 0.9rem; color: var(--primary); }
    td { padding: 10px 0; border-bottom: 1px solid var(--border); text-align: left; }
    .val-new { font-weight: bold; color: var(--accent); }
    .map-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(600px, 1fr)); gap: 40px; justify-items: center; }
    .map-card { text-align: center; background: white; border: 1px solid var(--border); padding: 20px; border-radius: 15px; width: 100%; }
    .map-zoom-container { width: 100%; max-width: 100%; margin: 10px auto; overflow: hidden; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); background: white; position: relative; }
    .map-zoom-container img { width: 100%; transition: transform 0.3s ease-out; cursor: zoom-in; transform-origin: center center; }
    .map-zoom-container img:hover { transform: scale(2.5); cursor: zoom-out; } 
    .legend-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; margin-top: 15px; }
    .legend-item { display: flex; align-items: center; gap: 10px; font-size: 0.85rem; font-weight: 600; }
    .swatch { width: 16px; height: 16px; border-radius: 50%; flex-shrink: 0; border: 1px solid rgba(0,0,0,0.1); }
