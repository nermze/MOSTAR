    VER_FLYE=$(flye --version 2>/dev/null || echo "not found")
    VER_EMU=$(emu --version 2>/dev/null || echo "not found")
    VER_POLY=$(polypolish --version 2>/dev/null || echo "not found")
    VER_AMR=$(amrfinder --version 2>/dev/null || echo "not found")
    VER_BWA=$(bwa 2>&1 | grep "Version" | cut -d' ' -f2 || echo "not found")
    VER_MEDAKA=$(medaka --version 2>/dev/null || echo "not found")
    VER_FILT=$(filtlong --version 2>/dev/null || echo "not found")
    VER_BAKTA=$(bakta --version 2>/dev/null | head -n1 | cut -d' ' -f2 || echo "not found")
    VER_FASTP=$(fastp --version 2>/dev/null | head -n1 || echo "not found")
    VER_SAM=$(samtools --version 2>/dev/null | head -n1 | cut -d' ' -f2 || echo "not found")

    # Write HTML
    cat <<EOF > "$HTML_OUT"
