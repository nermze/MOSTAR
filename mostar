        fi


    # Genome map 
    # Genome map
    local MAP_CONTENT

    # Path to the genome map generated by the Python script
    GENOME_MAP_PNG="$OUTDIR/amr_results/genome_map.png"

        if [[ -f "$GENOME_MAP_PNG" && -s "$GENOME_MAP_PNG" ]]; then
