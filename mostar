if command -v python3 &>/dev/null; then

python3 - <<PYEOF
import sys, os, json, numpy as np, pandas as pd
import matplotlib.pyplot as plt, matplotlib.patches as mpatches
import matplotlib.patheffects as pe

AMR_FILE   = "$OUTDIR/amr_results/AMR_Report.tsv"
GENOME_LEN = $(grep -v "^>" "$FINAL_ASM" | tr -d '\n' | wc -c)
OUTPUT_PNG = "$OUTDIR/amr_results/genome_map.png"

def identity_color(val):
    if val >= 100: return "#27ae60"   # green
    elif val >= 90: return "#3498db"  # blue
    else:           return "#e67e22"  # orange

def bp_to_angle(bp, gl):
    return np.pi / 2 - (bp / gl) * 2 * np.pi

def draw_gene_arrow(ax, r_in, r_out, start, end, gl, color, forward, alpha=0.92):
    a0, a1 = bp_to_angle(start, gl), bp_to_angle(end, gl)
    angles = np.linspace(a0, a1, max(60, int(abs(a0 - a1) * 400)))
    ax.fill(np.concatenate([r_out * np.cos(angles), r_in * np.cos(angles[::-1])]),
            np.concatenate([r_out * np.sin(angles), r_in * np.sin(angles[::-1])]),
            color=color, alpha=alpha, zorder=3, linewidth=0)
    r_mid = (r_in + r_out) / 2
    ta    = a1 if forward else a0
    ba    = ta + (0.03 if forward else -0.03)
    ax.fill([r_mid * np.cos(ta), r_out * np.cos(ba), r_in * np.cos(ba)],
            [r_mid * np.sin(ta), r_out * np.sin(ba), r_in * np.sin(ba)],
            color=color, alpha=min(alpha + 0.08, 1.0), zorder=4, linewidth=0)

try:
    if not os.path.exists(AMR_FILE) or os.path.getsize(AMR_FILE) <= 10:
        print("[WARN] AMR file missing or empty — skipping genome map"); sys.exit(0)
    if GENOME_LEN == 0:
        print("[WARN] Could not determine genome length — skipping genome map"); sys.exit(0)

    df = pd.read_csv(AMR_FILE, sep="\t")
    df["Start"]     = pd.to_numeric(df["Start"],                      errors="coerce").astype(int)
    df["Stop"]      = pd.to_numeric(df["Stop"],                       errors="coerce").astype(int)
    df["Strand"]    = df["Strand"].astype(str).str.strip()
    df["%Identity"] = pd.to_numeric(df["% Identity to reference"],    errors="coerce").fillna(0)
    df["Element symbol"] = df["Element symbol"].astype(str)
    df = df.dropna(subset=["Start","Stop"]).sort_values("Start").reset_index(drop=True)

    # Keep only highest %Identity gene per overlapping position group
    df["_pos_key"] = df["Start"].astype(str) + "_" + df["Stop"].astype(str)
    df = df.sort_values("%Identity", ascending=False).drop_duplicates(subset="_pos_key").sort_values("Start").reset_index(drop=True)

    fig, ax = plt.subplots(figsize=(16, 16))
    ax.set_xlim(-1.55, 1.55)
    ax.set_ylim(-1.55, 1.55)
    plt.tight_layout(pad=0)
    fig.savefig(OUTPUT_PNG, dpi=300, bbox_inches="tight", pad_inches=0.05, facecolor="white")

    R_OUT, R_IN = 1.00, 0.82
    ax.add_patch(plt.Circle((0,0), R_OUT, fill=False, ec="#bdc3c7", lw=0.7, zorder=1))
    ax.add_patch(plt.Circle((0,0), R_IN,  fill=False, ec="#bdc3c7", lw=0.7, zorder=1))

    # Tick marks every 0.2 Mb
    for bp in range(0, GENOME_LEN, 200_000):
        angle = bp_to_angle(bp, GENOME_LEN)
        ax.plot([R_OUT * np.cos(angle), (R_OUT + 0.04) * np.cos(angle)],
                [R_OUT * np.sin(angle), (R_OUT + 0.04) * np.sin(angle)],
                color="#95a5a6", lw=0.8, zorder=2)
        ax.text((R_OUT + 0.10) * np.cos(angle), (R_OUT + 0.10) * np.sin(angle),
                "0" if bp == 0 else f"{bp/1e6:.1f} Mb",
                ha="center", va="center", fontsize=12, color="#636e72",
                rotation=np.degrees(angle) - 90)

    # --- Draw all gene arrows ---
    seen_pct_bands, legend_handles = set(), []
    for idx, row in df.iterrows():
        start, end = row["Start"], row["Stop"]
        pct        = float(row["%Identity"])
        color      = identity_color(pct)
        forward    = row["Strand"] not in ("-", "minus")
        draw_gene_arrow(ax, R_IN, R_OUT, start, end, GENOME_LEN, color, forward)

        band = ">= 100%" if pct >= 100 else ">= 90%" if pct >= 90 else "< 90%"
        if band not in seen_pct_bands:
            seen_pct_bands.add(band)
            legend_handles.append(mpatches.Patch(facecolor=color, edgecolor="white",
                                                 label=f"Identity {band}"))

    # --- Smart label placement: stack overlapping labels radially ---
    df["_mid_angle"] = df.apply(
        lambda r: bp_to_angle((r["Start"] + r["Stop"]) // 2, GENOME_LEN), axis=1)

    # Group genes that are angularly close (within 0.25 rad ~14 degrees)
    CLUSTER_GAP = 0.25
    sorted_df = df.sort_values("_mid_angle", ascending=False).reset_index(drop=True)

    clusters = []
    used = [False] * len(sorted_df)
    for i in range(len(sorted_df)):
        if used[i]: continue
        cluster = [i]
        used[i] = True
        for j in range(i + 1, len(sorted_df)):
            if used[j]: continue
            if abs(sorted_df.loc[i, "_mid_angle"] - sorted_df.loc[j, "_mid_angle"]) < CLUSTER_GAP:
                cluster.append(j)
                used[j] = True
        clusters.append(cluster)

    for cluster in clusters:
        # Mean angle of the cluster = where the bracket/leader points
        angles = [sorted_df.loc[i, "_mid_angle"] for i in cluster]
        mean_angle = np.mean(angles)
        cos_a, sin_a = np.cos(mean_angle), np.sin(mean_angle)

        # Place labels outside the ring always, stacked radially
        BASE_R   = R_OUT + 0.18
        STEP_R   = 0.13   # radial gap between stacked labels

        for stack_idx, gene_idx in enumerate(cluster):
            row   = sorted_df.loc[gene_idx]
            pct   = float(row["%Identity"])
            color = identity_color(pct)

            gene_angle = row["_mid_angle"]
            r_label    = BASE_R + stack_idx * STEP_R

            # Short leader line from ring edge to first label only
            if stack_idx == 0:
                ax.plot([R_OUT * np.cos(gene_angle), (R_OUT + 0.15) * np.cos(mean_angle)],
                        [R_OUT * np.sin(gene_angle), (R_OUT + 0.15) * np.sin(mean_angle)],
                        color="#aab7b8", lw=0.6, zorder=2)

            # Connecting tick between stacked labels
            if stack_idx > 0:
                prev_r = BASE_R + (stack_idx - 1) * STEP_R
                ax.plot([(prev_r + 0.04) * cos_a, (r_label - 0.04) * cos_a],
                        [(prev_r + 0.04) * sin_a, (r_label - 0.04) * sin_a],
                        color="#d0d3d4", lw=0.4, zorder=2)

            rot = np.degrees(mean_angle) - 90
            if cos_a < 0:
                rot += 180

            t = ax.text(
                r_label * cos_a,
                r_label * sin_a,
                row["Element symbol"],
                ha="center", va="center",
                fontsize=12, rotation=rot,
                rotation_mode="anchor",
                color=color, zorder=5,
                fontweight="medium"
            )
            t.set_path_effects([pe.withStroke(linewidth=2.5, foreground="white")])

    ax.text(0,  0.07, "AMR Gene Map",                                ha="center", fontsize=18, fontweight="bold", color="#2d3436")
    ax.text(0, -0.03, f"{GENOME_LEN:,} bp  |  {len(df)} AMR hits",  ha="center", fontsize=14,  color="#7f8c8d")
    ax.text(0, -0.13, "▶ forward   ◀ reverse",                      ha="center", fontsize=14, color="#95a5a6", style="italic")

    legend_handles.sort(key=lambda p: p.get_label())
    fig.legend(handles=legend_handles, title="AMR Genes % Identity to reference", loc="lower center",
               ncol=3, fontsize=8.5, title_fontsize=9.5,
               framealpha=0.95, edgecolor="#bdc3c7", bbox_to_anchor=(0.5, 0.01))

    fig.savefig(OUTPUT_PNG, dpi=300, bbox_inches="tight", facecolor="white")
    plt.close(fig)
    print(f"[INFO] Genome map saved → {OUTPUT_PNG}")

except Exception as e:
    import traceback; traceback.print_exc()
    print(f"[ERROR] Genome map failed: {e}")
PYEOF

