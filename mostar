            <div class="legend-item"><div class="swatch" style="background:#e74c3c;"></div>Sulfonamides / Trimethoprim</div>
            <div class="legend-item"><div class="swatch" style="background:#1abc9c;"></div>Colistin / Polymyxin</div>
            <div class="legend-item"><div class="swatch" style="background:#e67e22;"></div>Fosfomycin</div>
            <div class="legend-item"><div class="swatch" style="background:#ff7675;"></div>Glycopeptides / Vancomycin</div>
            <div class="legend-item"><div class="swatch" style="background:#95a5a6;"></div>Biocides / Efflux</div>
            <div class="legend-item"><div class="swatch" style="background:#000000;"></div>Virulence / Unknown</div>
        </div>
    </div>

    <div class="card">
        <h2>Circular Genome Maps (AMR Locations)</h2>
        <div class="map-grid">${MAP_CONTENT:-<p style="padding:20px; color:#95a5a6;">No maps generated.</p>}</div>
