import sys, os, pandas as pd, numpy as np
import matplotlib.pyplot as plt
import matplotlib.patheffects as pe
from matplotlib.patches import Polygon
from Bio import SeqIO
from Bio.SeqUtils import gc_fraction

# Load environment
OUTDIR, FINAL_ASM, AMR_FILE, MAP_DIR = [os.environ.get(k) for k in ['OUTDIR', 'FINAL_ASM', 'AMR_FILE', 'MAP_DIR']]
os.makedirs(MAP_DIR, exist_ok=True)

def get_class_color(amr_class):
    # Standardize input to handle nan/empty
    c = str(amr_class).lower().strip()
    
    # Cell Wall Synthesis (Beta-lactams) - Blues
    if 'beta-lactam' in c or 'penicillin' in c or 'carbapenem' in c: return '#3498db'
    # Protein Synthesis - Purples/Pinks
    if 'tetracycline' in c: return '#9b59b6'
    if 'aminoglycoside' in c: return '#8e44ad'
    if 'macrolide' in c or 'lincosamide' in c or 'streptogramin' in c: return '#f1c40f'
    if 'phenicol' in c: return '#d35400' 
    # DNA/RNA Synthesis - Greens
    if 'quinolone' in c or 'fluoroquinolone' in c: return '#27ae60'
    if 'rifampicin' in c: return '#16a085'
    # Metabolic Pathways - Reds
    if 'sulfonamide' in c or 'trimethoprim' in c: return '#e74c3c'
    # Last Resort / Miscellaneous - Teals/Corals
    if 'colistin' in c or 'polymyxin' in c: return '#1abc9c'
    if 'fosfomycin' in c: return '#e67e22'
    if 'glycopeptide' in c or 'vancomycin' in c: return '#ff7675'
    # Biocides / Efflux - Grey
    if 'efflux' in c or 'disinfectant' in c: return '#95a5a6'
    
    # Virulence - Solid Black (Catching nan, empty, and unknown here)
    if c in ['na', 'nan', '', 'none', 'unknown']: return '#000000'
    
    # Default for classes not explicitly listed above
    return '#2c3e50'

def calculate_gc(sequence, bins=1000):
    n = len(sequence)
    step = max(1, n // bins)
    return np.array([gc_fraction(sequence[i:i+step]) for i in range(0, n, step)])

try:
    if not os.path.exists(FINAL_ASM) or os.path.getsize(FINAL_ASM) == 0:
        sys.exit(0)

    df = pd.read_csv(AMR_FILE, sep="\t") if os.path.exists(AMR_FILE) else pd.DataFrame()
    records = sorted(list(SeqIO.parse(FINAL_ASM, "fasta")), key=lambda x: len(x.seq), reverse=True)
    
    extra_idx = 1
    for i, record in enumerate(records):
        gl, cid, seq_str = len(record.seq), record.id, str(record.seq)
        is_main = (i == 0)
        type_label = "Main Assembly" if is_main else "Extra-Chromosomal DNA"
        file_name = "Main.png" if is_main else f"Extra-Chromosomal_DNA_{extra_idx}.png"
        if not is_main: extra_idx += 1

        fig = plt.figure(figsize=(10, 10))
        ax = fig.add_subplot(111, projection='polar')
        ax.set_theta_zero_location('N'); ax.set_theta_direction(-1) 
        ax.spines['polar'].set_visible(False); ax.grid(False); ax.set_yticklabels([]); ax.set_ylim(0, 1.4) 

        # Coordinate Scale
        ticks = np.linspace(0, 2*np.pi, 8, endpoint=False)
        t_labs = [f"{round((gl*t/(2*np.pi))/1e6,1)} Mb" if gl>1e6 else f"{int(gl*t/(2*np.pi)/1000)} kb" for t in ticks]
        ax.set_xticks(ticks); ax.set_xticklabels(t_labs, color='#7f8c8d', fontsize=15, fontweight='bold')
        for tick in ticks:
            ax.plot([tick, tick], [0, 1.15], color='#bdc3c7', lw=0.8, alpha=0.4, ls='--', zorder=0)

        # GC Content Track 
        gc_vals = calculate_gc(seq_str, bins=1000)
        avg_gc, t_gc = np.mean(gc_vals), np.linspace(0, 2*np.pi, len(gc_vals))
        ax.fill_between(t_gc, 0.70, 0.70 + (gc_vals - avg_gc) * 1.0, color='#bdc3c7', alpha=0.5, zorder=1) 

        # Backbone
        r_min, r_max = 0.88, 1.07
        ax.plot(np.linspace(0, 2*np.pi, 500), [r_min]*500, color='#bdc3c7', lw=1.5, alpha=0.6, zorder=2)
        ax.plot(np.linspace(0, 2*np.pi, 500), [r_max]*500, color='#bdc3c7', lw=1.5, alpha=0.6, zorder=2)

        hits_count = 0
        if not df.empty:
            hits = df[df["Contig id"].astype(str).str.contains(str(cid), na=False)].sort_values("Start")
            hits_count = len(hits)
            last_ang, stagger, r_mid, min_vis = -1.0, 0, (r_min + r_max) / 2, 0.03 

            for _, row in hits.iterrows():
                s_rad, e_rad = (row['Start']/gl)*2*np.pi, (row['Stop']/gl)*2*np.pi
                mid_rad, color = (s_rad + e_rad)/2, get_class_color(row["Class"])
                if str(row.get("Strand", "+")) == "+":
                    tip = e_rad if (e_rad - s_rad) > min_vis else s_rad + min_vis
                    pts = [(s_rad, r_min), (s_rad, r_max), (tip, r_mid)]
                else:
                    tip = s_rad if (e_rad - s_rad) > min_vis else e_rad - min_vis
                    pts = [(e_rad, r_min), (e_rad, r_max), (tip, r_mid)]
                
                ax.add_patch(Polygon(pts, facecolor=color, edgecolor='white', lw=1.8, alpha=1.0, zorder=15))

                if abs(mid_rad - last_ang) < 0.45: stagger = (stagger + 1) % 6
                else: stagger = 0
                l_rad = 1.35 + (stagger * 0.22)
                last_ang = mid_rad
                ax.plot([mid_rad, mid_rad], [r_max, l_rad-0.03], color='#bdc3c7', lw=1.2, ls=':', alpha=0.7)
                t = ax.text(mid_rad, l_rad, row['Element symbol'], color=color, fontsize=12, fontweight='bold', ha='center', va='center')
                t.set_path_effects([pe.withStroke(linewidth=4, foreground="white")])

        # CENTER TEXT STACK 
        ax.text(0, 0.45, "AMR Gene Map", ha='center', va='center', fontsize=24, fontweight='bold', color='#2c3e50')
        ax.text(0, 0.32, f"GC Content: {avg_gc*100:.1f}%", ha='center', va='center', fontsize=13, color='#7f8c8d')
        ax.text(0, 0.0, type_label, ha='center', va='center', fontsize=18, fontweight='bold', color='#34495e')
        ax.text(np.pi, 0.22, f"{gl:,} bp", ha='center', va='center', fontsize=16, fontweight='bold', color='#2c3e50')
        ax.text(np.pi, 0.40, f"{hits_count} AMR hits", ha='center', va='center', fontsize=12, color='#7f8c8d')

        plt.savefig(os.path.join(MAP_DIR, file_name), dpi=300, bbox_inches='tight', pad_inches=0.2, transparent=True)
        plt.close()

    # GENERATE SUMMARY TABLE
    if not df.empty:
        html = '<div class="table-container" style="margin-top:40px; font-family:sans-serif;">'
        html += '<h3 style="color:#2c3e50; border-bottom:2px solid #bdc3c7; padding-bottom:10px;">AMR & Virulence Summary</h3>'
        html += '<table style="width:100%; border-collapse:collapse; text-align:left;">'
        html += '<thead style="background-color:#f8f9fa;"><tr>'
        html += '<th style="padding:12px; border-bottom:2px solid #dee2e6;">Symbol</th><th>Class</th><th>Position</th><th>Strand</th><th>Identity</th></tr></thead><tbody>'
        
        for _, row in df.sort_values(["Contig id", "Start"]).iterrows():
            raw_class = str(row["Class"]).strip()
            
            # Logic to swap 'nan' for 'Virulence'
            if raw_class.lower() in ['nan', '', 'none', 'na']:
                display_class = "Virulence"
            else:
                display_class = raw_class

            color = get_class_color(raw_class)
            
            html += f'<tr style="border-bottom:1px solid #dee2e6;">'
            html += f'<td style="padding:12px;"><span style="background:{color}; color:white; padding:4px 10px; border-radius:12px; font-weight:bold; font-size:0.9em;">{row["Element symbol"]}</span></td>'
            html += f'<td style="padding:12px;">{display_class}</td>'
            html += f'<td style="padding:12px; font-family:monospace;">{row["Start"]:,}-{row["Stop"]:,}</td>'
            html += f'<td>{row["Strand"]}</td>'
            html += f'<td style="padding:12px; font-weight:bold; color:#000000;">{row["% Identity to reference"]}%</td></tr>'
            
        html += '</tbody></table></div>'
        with open(os.path.join(OUTDIR, "amr_summary.html"), "w") as f: f.write(html)

except Exception as e:
    with open(os.path.join(OUTDIR, "logs/viz_error.log"), "w") as f: f.write(str(e))
