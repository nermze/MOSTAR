    export FINAL_LEN="${MEDAKA_LEN:-0}"
    export FINAL_CNT="${MEDAKA_CNT:-0}"
    export FINAL_N50="${MEDAKA_N50:-0}"
    
    export BWA_MAPPING_RATE="N/A"
    export MEAN_DEPTH="N/A"
    export POS_CHANGED=0
    export ZERO_DEPTH_BP=0
fi

echo "[$(date +%T)] Polypolish hybrid polishing completed successfully!"
echo "[$(date +%T)] Polypolish log: $OUTDIR/logs/polypolish.log"
echo "[$(date +%T)] BWA mapping rate: ${BWA_MAPPING_RATE}%"

