    POS_CHANGED=$(grep "positions changed" "$OUTDIR/logs/polypolish.log" | awk '{print $1}' | tr -d ',')
    ZERO_DEPTH_BP=$(grep "depth of zero" "$OUTDIR/logs/polypolish.log" | awk '{print $1}' | tr -d ',')
else
    cp "$OUTDIR/medaka/consensus.fasta" "$FINAL_ASM"
    BWA_MAPPING_RATE="N/A"
    MEAN_DEPTH="N/A"
    POS_CHANGED=0
    ZERO_DEPTH_BP=0
fi

