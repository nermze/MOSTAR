#!/usr/bin/env bash
set -euo pipefail
trap 'echo "[ERROR] Pipeline failed at line $LINENO"; exit 1' ERR
START_TIME=$(date +%s)

VERSION="1.0.0"
OUTDIR=""
FINAL_ASM=""
START_TIME=$(date +%s)
TOTAL_LEN=0
N50_VAL=0
CONTIG_CNT=0
TOP_TAXID="N/A"
TOP_ABUNDANCE="0.00"
ASM_SPECIES_FULL="Unknown"


# MOSTAR is a comprehensive bioinformatics pipeline for proceccsing ONT-reads.
# * Hybrid-assembly
# * Ont-Only assembly
# * Polishing
# * Functional annotaiton
# * AMR profiling
# * Taxonomic profiling
# * Built-in Quality controls
# * HTML report generation with all the stats and results

# Help Menu
usage() {
    echo ""
    echo "A comprehensive bioinformatics pipeline by Nermin Zecic, <nermze@gmail.com>"
    echo ""
    echo "      __      __   __    ____  _______   __     _____             "
    echo "      | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "      | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "      |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""
    echo "     Assembly, Polishing, Annotation & AMR of ONT reads (v1.0.0)"
    echo ""
    echo "      Tip: MOSTAR can perform both hybrid and regular assembly"
    echo ""
    echo "Hybrid mode: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism] -1 R1.fq -2 R2.fq"
    echo "ONT-only: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism]"
    echo ""
    echo "Required:"
    echo "  --ont           ONT Long reads [.fastq.gz]"
    echo "  --genome-size   Genome size [e.g., 2.1m, 5.0m, 4g]"
    echo "  --output        Output directory"
    echo "  --model        Medaka model [Default: r1041_e82_400bps_sup_v5.2.0]"
    echo ""
    echo "Options:"
    echo "  --r1/--r2       Illumina R1/R2 [Enables Hybrid mode]"
    echo "  --organism      Organism for AMRFinder+ [e.g., Escherichia, Staphylococcus]"
    echo "  --filtlong-cov  Filtlong target coverage [Default: 100]"
    echo "  --meta          Enbale uneven coverage mode for Flye [Default: disabled]"
    echo ""
    echo "Annotation options:"
    echo "  --bakta-db      BAKTA database path, enables annotation"
    echo "  --bakta-ref     BAKTA annotation reference [GFF]"
    echo "  --complete      BAKTA enable if all sequences are complete (circular) [Default: disabled]"
    echo ""
    echo "Classification options:"
    echo "  --kraken-db     Requires pre-built Kraken2 database"
    echo "  --confidence    Kraken2 confidence threshold [Default: 0.1]"
    echo "  --emu-db        Requires EMU database path, will auto-download [16s Amplicon classifier]"
    echo ""
    echo "Other options:"
    echo "  --cleanup       Cleanup intermediate files"
    echo "  --threads       CPU threads [Default: 10]"
    echo "  --help          Show this help message and exit"
    echo ""
    echo MOSTAR v1.0.0
    exit 1
}

generate_html_report() {
    # Initialize local variables
    local OD="${OUTDIR:-.}"
    local FA="${FINAL_ASM:-}"
    local ONT_VAL="${ONT:-sample}"
    local AMR_FILE="$OD/amr_results/AMR_Report.tsv"
    local HTML_OUT="$OD/MOSTAR_Final_Report.html"
    local MAP_DIR="$OD/amr_results/maps"  
    local REPORT_SAMPLE; REPORT_SAMPLE=$(basename "$ONT_VAL")
    local REPORT_DATE; REPORT_DATE=$(date '+%Y-%m-%d %H:%M:%S')
    local DURATION; DURATION=$(( ($(date +%s) - ${START_TIME:-0}) / 60 ))
    local TAXID_DISPLAY="<span style='color:#95a5a6;'>Not run</span>"
    local POS_CHANGED=0
    local HYBRID_CARDS=""
    local METRICS_BLOCKS=""
    local TAX_CARDS=""
    local TOTAL_LEN=0
    local N50_VAL=0
    local CONTIG_CNT=0
    local FLYE_V=$(flye --version 2>/dev/null || echo "N/A")
    local MEDAKA_V=$(medaka --version 2>/dev/null | head -n 1 || echo "N/A")
    local AMRF_V=$(amrfinder --version 2>/dev/null || echo "N/A")
    local BAKTA_V=$(bakta --version 2>/dev/null || echo "N/A")
    local KRAKEN_V=$(kraken2 --version 2>/dev/null | head -n 1 | awk '{print $NF}' || echo "N/A")
    local FASTP_V=$(fastp --version 2>&1 | awk '{print $NF}' || echo "N/A")
    local BWA_V=$(bwa 2>&1 | grep "Version:" | awk '{print $NF}' || echo "N/A")
    local FILT_V=$(filtlong --version 2>/dev/null || echo "N/A")
    local POLY_V=$(polypolish --version 2>/dev/null || echo "N/A")
    local EMU_V="$(emu --version 2>/dev/null || echo "N/A")"

    # Assembly Metrics from the final polished File
    if [[ -f "$FA" ]]; then
        TOTAL_LEN=$(grep -v "^>" "$FA" | tr -d '[:space:]' | wc -c)
        N50_VAL=$TOTAL_LEN
        CONTIG_CNT=$(grep -c "^>" "$FA")
        
        # Calculate Polished Bases if Medaka baseline exists (MEDAKA_LEN=$M_LEN)
        if [[ -n "${MEDAKA_LEN:-}" && "$MEDAKA_LEN" -gt 0 ]]; then
            local DIFF=$(( TOTAL_LEN - MEDAKA_LEN ))
            POS_CHANGED=${DIFF#-}
        fi
    fi

    # Taxonomy Cards & Display Logic 
    if [[ -n "${ASM_SPECIES_FULL:-}" && "$ASM_SPECIES_FULL" != "Unknown" ]]; then
        TAX_CARDS+="<div class='qc-card'><span class='qc-label'>Kraken2 Species ID</span><span class='qc-val'>$ASM_SPECIES_FULL</span></div>"
    fi

    if [[ "${TOP_TAXID:-N/A}" != "N/A" ]]; then
        TAXID_DISPLAY="<a href='https://www.ncbi.nlm.nih.gov/datasets/taxonomy/tree/?taxon=${TOP_TAXID}' target='_blank' style='color:#3498db; text-decoration:none;'>${TOP_TAXID} &#128279;</a>"
        TAX_CARDS+="<div class='qc-card'><span class='qc-label'>EMU TAXONOMY</span><span class='qc-val'>$TAXID_DISPLAY</span></div>"
        if [[ -n "${TOP_ABUNDANCE:-}" ]]; then
            TAX_CARDS+="<div class='qc-card'><span class='qc-label'>ABUNDANCE</span><span class='qc-val'>${TOP_ABUNDANCE}%</span></div>"
        fi
    fi

    # Hybrid Metrics
    if [[ -n "${R1:-}" ]]; then
        local CLEAN_DEPTH="${MEAN_DEPTH//x/}" 
        local POL_DISP; POL_DISP=$(printf "%'d" "${POS_CHANGED:-0}")
        local GAP_DISP; GAP_DISP=$(printf "%'d" "${ZERO_DEPTH_BP:-0}")
        
        HYBRID_CARDS="
        <div class='qc-card'><span class='qc-label'>Short-Read Depth</span><span class='qc-val'>${CLEAN_DEPTH}x</span></div>
        <div class='qc-card'><span class='qc-label'>Polished Bases</span><span class='qc-val'>$POL_DISP bp</span></div>
        <div class='qc-card'><span class='qc-label'>Zero-Depth Gaps</span><span class='qc-val' style='color:${ZERO_DEPTH_BP:+#e74c3c}'>$GAP_DISP bp</span></div>"
    fi

    if [[ -n "${R1:-}" ]]; then
        # HYBRID MODE
        METRICS_BLOCK="<div class='card'>
            <h2>Assembly Metrics Comparison</h2>
            <table>
                <thead>
                    <tr>
                        <th style='width: 35%; padding-left: 0;'>Metric</th>
                        <th style='color: #7f8c8d;'>Medaka (ONT)</th>
                        <th style='color: var(--accent);'>Final (Polished)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Total Genome Length</td><td>$(printf "%'d" ${MEDAKA_LEN:-0}) bp</td><td class='val-new'>$(printf "%'d" ${FINAL_LEN:-0}) bp</td></tr>
                    <tr><td>Contig Count</td><td>${MEDAKA_CNT:-0}</td><td class='val-new'>${FINAL_CNT:-0}</td></tr>
                    <tr><td>Assembly N50</td><td>$(printf "%'d" ${MEDAKA_N50:-0}) bp</td><td class='val-new'>$(printf "%'d" ${FINAL_N50:-0}) bp</td></tr>
                </tbody>
            </table>
            <p style='font-size: 0.8rem; color: #7f8c8d; margin-top: 10px;'>* Short-read polishing resulted in a net change of <b>$(printf "%'d" ${POS_CHANGED:-0})</b> positions.</p>
        </div>"
    else
        # ONT-ONLY MODE
        METRICS_BLOCK="<div class='card'>
            <h2>Assembly Metrics (ONT-Only)</h2>
            <table>
                <thead>
                    <tr>
                        <th style='width: 50%; padding-left: 0;'>Metric</th>
                        <th style='color: var(--accent);'>Results</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Total Genome Length</td><td class='val-new'>$(printf "%'d" ${FINAL_LEN:-0}) bp</td></tr>
                    <tr><td>Contig Count</td><td class='val-new'>${FINAL_CNT:-0}</td></tr>
                    <tr><td>Assembly N50</td><td class='val-new'>$(printf "%'d" ${FINAL_N50:-0}) bp</td></tr>
                </tbody>
            </table>
        </div>"
    fi


    # Map Gallery with Base64 & Zoom
    local MAP_CONTENT=""
    if [[ -d "$MAP_DIR" ]]; then
        for img in "$MAP_DIR"/*.png; do
            if [[ -f "$img" ]]; then
                local b64; b64=$(base64 < "$img" | tr -d '\n')
                local label; label=$(basename "$img" .png | sed 's/_/ /g')
                MAP_CONTENT+="<div class='map-card'><h4>$label</h4><div class='map-zoom-container'><img src='data:image/png;base64,$b64' alt='$label'></div><p style='font-size:0.7rem; color:#95a5a6; margin-top:5px;'>Hover to zoom</p></div>"
            fi
        done
    fi

    local PYTHON_SUMMARY=""
    [[ -f "$OD/amr_summary.html" ]] && PYTHON_SUMMARY=$(cat "$OD/amr_summary.html")

    # Start Heredoc
    cat <<EOF > "$HTML_OUT"
