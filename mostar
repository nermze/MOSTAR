#!/usr/bin/env bash
set -e

# --- Help Menu ---
usage() {
    echo "======================================================================="
    echo ""  
    echo "                            Mostar-ASM" 
    echo "     Assembly, Polishing, Annotation & AMR of ONT reads (v1.3.0)"
    echo ""  
    echo "======================================================================="
    echo "Usage: mostar -1 R1.fq.gz -2 R2.fq.gz -n ont.fq.gz -g 2.1m -o out_dir"
    echo ""
    echo "Required Arguments:"
    echo "  -1  Forward Illumina reads (.fastq.gz)"
    echo "  -2  Reverse Illumina reads (.fastq.gz)"
    echo "  -n  ONT Long reads (.fastq.gz)"
    echo "  -g  Estimated genome size (e.g., 2.1m or 5.0m)"
    echo "  -o  Output directory"
    echo "  -m  Important! Medaka model (Default: r1041_e82_400bps_sup_v5.2.0)"
    echo ""
    echo "Options:"
    echo "  -a  Reference GenBank for annotation (Prokka --proteins)"
    echo "  -t  CPU threads (Default: 10)"
    echo "  -h  Show this help message"
    echo "======================================================================="
    exit 1
}

# Defaults parameters
THREADS=10
MEDAKA_MODEL="r1041_e82_400bps_sup_v5.2.0"
PROT_REF=""

while getopts "1:2:n:g:o:a:t:m:h" opt; do
    case ${opt} in
        1) R1=$OPTARG ;;
        2) R2=$OPTARG ;;
        n) ONT=$OPTARG ;;
        g) GSIZE=$OPTARG ;;
        o) OUTDIR=$OPTARG ;;
        a) PROT_REF=$OPTARG ;;
        t) THREADS=$OPTARG ;;
        m) MEDAKA_MODEL=$OPTARG ;;
        h) usage ;;
    esac
done

if [[ -z "$R1" || -z "$R2" || -z "$ONT" || -z "$GSIZE" || -z "$OUTDIR" ]]; then usage; fi

# Create directory structure
mkdir -p "$OUTDIR/intermediate" "$OUTDIR/logs" "$OUTDIR/amr_results"

# Perform short read trimming using FastP
echo "[$(date +%T)] 1/7: Short-read QC (fastp)..."
fastp --in1 "$R1" --in2 "$R2" \
      --out1 "$OUTDIR/intermediate/sh_R1.fq.gz" --out2 "$OUTDIR/intermediate/sh_R2.fq.gz" \
      --thread "$THREADS" --json "$OUTDIR/logs/fastp.json" --html "$OUTDIR/logs/fastp.html" > /dev/null 2>&1

# Perform long-read filtering 
echo "[$(date +%T)] 2/7: Long-read filtering (filtlong)..."
filtlong --min_length 1000 --keep_percent 90 "$ONT" | gzip > "$OUTDIR/intermediate/ont_filt.fq.gz"

# De-novo assembly using FLYE
echo "[$(date +%T)] 3/7: De Novo Assembly (Flye) [$GSIZE]..."
flye --nano-hq "$OUTDIR/intermediate/ont_filt.fq.gz" --genome-size "$GSIZE" --threads "$THREADS" --out-dir "$OUTDIR/flye"

# Polish long reads and extract consenus sequence using MEDAKA
echo "[$(date +%T)] 4/7: Long-read polishing (Medaka)..."
medaka_consensus -i "$OUTDIR/intermediate/ont_filt.fq.gz" -d "$OUTDIR/flye/assembly.fasta" \
                 -m "$MEDAKA_MODEL" -t "$THREADS" -o "$OUTDIR/medaka"

# Align short reads to the extracted consesus sequence 
echo "[$(date +%T)] 5/7: Hybrid Polishing (BWA + Polypolish)..."
bwa index "$OUTDIR/medaka/consensus.fasta" > /dev/null 2>&1
bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R1.fq.gz" > "$OUTDIR/intermediate/1.sam"
bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R2.fq.gz" > "$OUTDIR/intermediate/2.sam"

# Filter 
polypolish filter --in1 "$OUTDIR/intermediate/1.sam" --in2 "$OUTDIR/intermediate/2.sam" \
                  --out1 "$OUTDIR/intermediate/f1.sam" --out2 "$OUTDIR/intermediate/f2.sam"
# Polish 
polypolish polish "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/f1.sam" "$OUTDIR/intermediate/f2.sam" > "$OUTDIR/mostar_Assembly.fasta"

# Annotate using PROKKA 
echo "[$(date +%T)] 6/7: Functional Annotation (Prokka)..."
echo -e '#!/bin/bash\necho "tbl2asn 25.8"' > "$OUTDIR/intermediate/tbl2asn"
chmod +x "$OUTDIR/intermediate/tbl2asn"

PROKKA_CMD="PATH=\"$OUTDIR/intermediate:\$PATH\" prokka --outdir \"$OUTDIR/annotation\" --prefix mostar_Annotation --cpus \"$THREADS\" --kingdom Bacteria"
if [[ -n "$PROT_REF" ]]; then PROKKA_CMD="$PROKKA_CMD --proteins \"$PROT_REF\""; fi
eval "$PROKKA_CMD \"$OUTDIR/mostar_Assembly.fasta\""

# Run NCBI AMRFinderPlus
echo "[$(date +%T)] 7/7: AMR Gene Detection (AMRFinderPlus)..."
# Check if AMR database is installed, if not, try to update
if ! amrfinder --database_version > /dev/null 2>&1; then
    echo "Notice: AMR database not found. Attempting to download..."
    amrfinder -u
fi

amrfinder -n "$OUTDIR/mostar_Assembly.fasta" \
          -p "$OUTDIR/annotation/mostar_Annotation.faa" \
          -g "$OUTDIR/annotation/mostar_Annotation.gff" \
          --threads "$THREADS" \
          --plus --protein_end_minus 10 \
          > "$OUTDIR/amr_results/AMR_Report.tsv"

echo "======================================================================="
echo "  MOSTAR-ASM PIPELINE COMPLETE"
echo "  Final Assembly: $OUTDIR/mostar_Assembly.fasta"
echo "  AMR Report:     $OUTDIR/amr_results/AMR_Report.tsv"
echo "  If you found this pipeline helpful please cite "  
echo "======================================================================="
