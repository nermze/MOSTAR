    echo ""
    echo "=============================================================================="
    echo "[$(date +%T)] Cleaning up and deleting intermediate files"
    echo "=============================================================================="
    echo ""
    echo ""
    rm -f "$OUTDIR/intermediate/"*.sam "$OUTDIR/intermediate/ont_filt.fq.gz"
fi

# ==============================================================================
#                       AMR and Genome Visualization
# ==============================================================================
PLOT_BASE64=""

if command -v python3 &>/dev/null; then
    COLOR_JSON=$(python3 -c "
import json
pairs = '''$(for cls in "${!AMR_COLORS[@]}"; do printf '%s=%s\n' "$cls" "${AMR_COLORS[$cls]}"; done)'''
d = {}
for line in pairs.strip().split('\n'):
    if '=' in line:
        k, v = line.split('=', 1)
