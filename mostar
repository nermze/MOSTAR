#!/usr/bin/env bash
set -euo pipefail


# MOSTAR is a comprehensive bioinformatics pipeline for proceccsing ONT-reads.
# * Hybrid-assembly
# * Assembly without short-reads
# * Polishing
# * Functional annotaiton
# * AMR profiling
# * Taxonomic profiling
# * Built-in Quality controls

# Help Menu
usage() {
    echo ""
    echo "A comprehensive bioinformatics pipeline by Nermin Zecic, <nermze@gmail.com>"
    echo ""
    echo "      __      __   __    ____  _______   __     _____             "
    echo "      | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "      | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "      |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""
    echo "Assembly, Polishing, Annotation & AMR of ONT reads (v1.0.0)"
    echo ""
    echo "Tip: Mostar can perform both hybrid and regular assembly"
    echo ""
    echo "Hybrid Assembly: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism] -1 R1.fq -2 R2.fq"
    echo "Regular Assembly: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism]"
    echo ""
    echo "Required:"
    echo "  -n  ONT Long reads (.fastq.gz)"
    echo "  -g  Genome size (e.g., 2.1m, 5.0m, 4g)"
    echo "  -o  Output directory"
    echo "  -p  Organism for AMRFinder+ (e.g., Escherichia, Staphylococcus)"
    echo ""
    echo "Options:"
    echo "  -1/-2 Illumina R1/R2 (Enables Hybrid mode)"
    echo "  -k    Path to the EMU Database"
    echo "  -m    Medaka model (Default: r1041_e82_400bps_sup_v5.2.0)"
    echo "  -f    Filtlong target coverage (Default: 100)"
    echo "  -c    Prokka minimum coverage % (Default: 80)"
    echo "  -i    Prokka e-value (Default: 1e-09)"
    echo "  -a    Proteins/GenBank for annotation"
    echo "  -x    Cleanup intermediate files"
    echo "  -t    CPU threads (Default: 10)"
    echo ""
    echo MOSTAR v1.0.0
    exit 1
}

# Generate a clean HTML-report with all the statistics
generate_html_report() {
    local HTML_OUT="$OUTDIR/MOSTAR_Final_Report.html"
    echo "[$(date +%T)] Generating Data-Heavy Clinical Dashboard..."

    # Capture Variables
    local READS="${FILTERED_READ_COUNT:-0}"
    local BWA_RATE="${BWA_MAPPING_RATE:-N/A}"
    local DEPTH="${MEAN_DEPTH:-N/A}"
    local COVERAGE="${GENOME_COV:-N/A}"
    local ACCURACY="${EST_ACCURACY:-N/A}"
    local Q_SCORE="${Q_VAL:-N/A}"
    local CHANGES="${CHANGES_CNT:-0}"
    local TAXID_VAL="${TOP_TAXID:-N/A}"
    
    # AMR Logic
    local AMR_ROWS
    if [[ -f "$OUTDIR/amr_results/AMR_Report.tsv" ]]; then
        AMR_ROWS=$(awk -F'\t' 'NR>1 {
            printf "<tr><td><span class=\"amr-tag\">%s</span></td><td><small>%s</small></td><td><div style=\"display:flex; align-items:center; gap:12px;\"><div class=\"val\" style=\"min-width:60px;\">%.2f%%</div><div class=\"identity-bar\" style=\"flex-grow:1;\"><div class=\"identity-fill\" style=\"width:%.2f%%\"></div></div></div></td></tr>", $6, $11, $17, $17
        }' "$OUTDIR/amr_results/AMR_Report.tsv" | head -n 12)
    else
        AMR_ROWS="<tr><td colspan='3' style='text-align:center; padding:30px; color:#95a5a6;'>No resistance genes identified.</td></tr>"
    fi

    cat <<EOF > "$HTML_OUT"
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        :root { --primary: #1a2a3a; --accent: #3498db; --bg: #f8f9fa; --success: #27ae60; --gray: #7f8c8d; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); padding: 25px; color: var(--primary); }
        .wrapper { max-width: 1100px; margin: auto; }
        .header { background: var(--primary); color: white; padding: 25px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .qc-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 20px; }
        .qc-card { background: white; padding: 15px; border-radius: 10px; border: 1px solid #edf2f7; text-align: center; }
        .qc-label { font-size: 0.7rem; color: var(--gray); text-transform: uppercase; display: block; margin-bottom: 5px; }
        .qc-val { font-weight: bold; font-size: 1rem; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; }
        td { padding: 12px 10px; border-bottom: 1px solid #f1f1f1; }
        .val { font-weight: bold; color: var(--accent); }
        .amr-tag { background: #fff5f5; color: #c0392b; padding: 3px 8px; border-radius: 4px; font-weight: bold; border: 1px solid #fed7d7; }
        .identity-bar { height: 8px; background: #eee; border-radius: 4px; overflow: hidden; }
        .identity-fill { height: 100%; background: var(--success); }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="header">
            <div>
                <h1 style="margin:0;">MOSTAR <span style="font-weight:200;">Pipeline</span></h1>
                <p style="margin:5px 0 0; opacity:0.8;">Sample: $(basename "$ONT")</p>
            </div>
            <div style="text-align:right;">
                <b>Hybrid (Polypolish)</b><br><small>$(date)</small>
            </div>
        </div>

        <div class="qc-row">
            <div class="qc-card"><span class="qc-label">Filtlong Reads</span><span class="qc-val">$READS</span></div>
            <div class="qc-card"><span class="qc-label">Mapping Rate</span><span class="qc-val">$BWA_RATE%</span></div>
            <div class="qc-card"><span class="qc-label">Mean Depth</span><span class="qc-val">$DEPTH</span></div>
            <div class="qc-card"><span class="qc-label">Genome Coverage</span><span class="qc-val">$COVERAGE</span></div>
        </div>

        <div class="grid">
            <div class="card">
                <h2 style="font-size:0.8rem; color:var(--gray); text-transform:uppercase;">Assembly & Polishing</h2>
                <table>
                    <tr><td>Total Length</td><td class="val">${TOTAL_LEN:-0} bp</td></tr>
                    <tr><td>Pre-Polish Accuracy</td><td class="val">$ACCURACY ($Q_SCORE)</td></tr>
                    <tr><td>Positions Changed</td><td class="val">$CHANGES</td></tr>
                    <tr><td>Medaka Model</td><td class="val" style="font-size:0.75rem;">$MEDAKA_MODEL</td></tr>
                </table>
            </div>
            <div class="card">
                <h2 style="font-size:0.8rem; color:var(--gray); text-transform:uppercase;">Taxonomic ID (EMU)</h2>
                <div style="font-size: 2.2rem; font-weight: 800; margin: 10px 0; color:var(--accent);">TaxID: $TAXID_VAL</div>
                <div>Abundance: <span class="val">${TOP_CONF:-0}%</span></div>
                <a href="https://www.ncbi.nlm.nih.gov/Taxonomy/Browser/wwwtax.cgi?id=$TAXID_VAL" target="_blank" style="font-size:0.75rem; color:var(--accent); text-decoration:none; margin-top:10px; display:inline-block;">Verify on NCBI →</a>
            </div>
        </div>

        <div class="card">
            <h2 style="font-size:0.8rem; color:var(--gray); text-transform:uppercase;">Resistance Profile (NCBI)</h2>
            <table>
                <tbody>$AMR_ROWS</tbody>
            </table>
        </div>

        <footer style="text-align:center; padding:30px; font-size:0.7rem; color:var(--gray);">
            MOSTAR Pipeline | Developed by Nermin Zecic | 2026
        </footer>
    </div>
</body>
</html>
EOF

    echo "[$(date +%T)] Dashboard generated: $HTML_OUT"
}


# Defaults
THREADS=10
MEDAKA_MODEL="r1041_e82_400bps_sup_v5.2.0"
R1=""; R2=""; PROT_REF=""; ORGANISM=""
PROKKA_COV=80; PROKKA_EVAL="1e-09"; FILTLONG_COV=100
PROKKA_SUCCESS=false
CLEANUP=false
EMU_DB=""
TOP_SPECIES="Not Run"; TOP_CONF="0"

# Options and arguments
while getopts "1:2:n:g:o:a:t:m:c:i:f:p:k:xh" opt; do
    case ${opt} in
        1) R1=$OPTARG ;;
        2) R2=$OPTARG ;;
        n) ONT=$OPTARG ;;
        g) GSIZE=$OPTARG ;;
        o) OUTDIR=$OPTARG ;;
        a) PROT_REF=$OPTARG ;;
        t) THREADS=$OPTARG ;;
        c) PROKKA_COV=$OPTARG ;;
        i) PROKKA_EVAL=$OPTARG ;;
        m) MEDAKA_MODEL=$OPTARG ;;
        p) ORGANISM=$OPTARG ;;
        k) EMU_DB=$OPTARG ;;
        f) FILTLONG_COV=$OPTARG ;;
        x) CLEANUP=true ;;
        h) usage ;;
        *) usage ;;
    esac
done

if [[ -z "${ONT:-}" || -z "${GSIZE:-}" || -z "${OUTDIR:-}" ]]; then usage; fi

    echo ""
    echo "      __      __   __    ____  _______   __     _____             "
    echo "      | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "      | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "      |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""


# Init directories
mkdir -p "$OUTDIR/intermediate" "$OUTDIR/logs" "$OUTDIR/amr_results"
REAL_OUT=$(cd "$OUTDIR" && pwd)
FINAL_ASM="$REAL_OUT/mostar_Assembly.fasta"

echo ""
echo ""
echo "=============================================================================="
echo "          Performing Short-read filtering using FastP"
echo "=============================================================================="
echo ""
echo ""

# Short-read QC with FastP [Optional]
if [[ -n "$R1" && -n "$R2" ]]; then
    echo "[$(date +%T)]: Running Short-read QC using using FastP"
    fastp --in1 "$R1" --in2 "$R2" --out1 "$OUTDIR/intermediate/sh_R1.fq.gz" --out2 "$OUTDIR/intermediate/sh_R2.fq.gz" \
          --thread "$THREADS" --json "$OUTDIR/logs/fastp.json" --html "$OUTDIR/logs/fastp.html" > /dev/null 2>&1
fi
echo ""
echo ""
echo "=============================================================================="
echo "          Performing Long-read filtering using Filtlong"
echo "=============================================================================="
echo ""
echo ""
# Long-read filtering with Filtlong
G_VAL=$(echo "${GSIZE:-0}" | sed 's/[a-zA-Z]//g')
UNIT=$(echo "${GSIZE:-}" | grep -o '[a-zA-Z]' || echo "")
if [[ -z "$G_VAL" ]]; then G_VAL=0; fi
TARGET_VAL=$(echo "$G_VAL * $FILTLONG_COV" | bc | cut -d. -f1)
TARGET_STR="${TARGET_VAL}${UNIT}"
echo "[$(date +%T)] 2/7: Long-read filtering (Filtlong)..."
echo "[$(date +%T)] Target depth: $FILTLONG_COV x (Targeting: $TARGET_STR)"

if [[ -n "${R1:-}" ]]; then
    echo "[$(date +%T)] Hybrid filtering mode active..."
    filtlong --min_length 1000 --keep_percent 90 --target_bases "$TARGET_STR" \
             -1 "$OUTDIR/intermediate/sh_R1.fq.gz" \
             -2 "$OUTDIR/intermediate/sh_R2.fq.gz" \
             "$ONT" > "$OUTDIR/intermediate/ont_filt.fq" 2> "$OUTDIR/logs/filtlong.log"
else
    echo "[$(date +%T)] Long-read only filtering mode active..."
    filtlong --min_length 1000 --keep_percent 90 --target_bases "$TARGET_STR" \
             "$ONT" > "$OUTDIR/intermediate/ont_filt.fq" 2> "$OUTDIR/logs/filtlong.log"
fi

echo "[$(date +%T)] Finalizing filtered reads..."
gzip -f "$OUTDIR/intermediate/ont_filt.fq"

if [[ -f "$OUTDIR/logs/filtlong.log" ]]; then
    READS_RAW=$(grep -A 1 "Scoring long reads" "$OUTDIR/logs/filtlong.log" | tail -n 1 | awk '{print $1$2}' | tr -d '[:alpha:][:space:]')
    FILTERED_READ_COUNT=$(printf "%'d" "${READS_RAW:-0}")
fi

echo ""
echo ""
echo "=============================================================================="
echo "              Running Taxonomic classification with EMU"
echo "=============================================================================="
echo ""
echo""
# Taxonomic classification with EMU [Optional]
if [[ -n "${EMU_DB:-}" ]]; then
    EMU_FASTA="$EMU_DB/species_taxid.fasta"
    EMU_TAX="$EMU_DB/taxonomy.tsv"

    # Database Auto-Download
    if [[ ! -f "$EMU_FASTA" || ! -f "$EMU_TAX" ]]; then
        echo "[$(date +%T)] Emu database not found in $EMU_DB. Initiating auto-download..."
        mkdir -p "$EMU_DB"
        (
            cd "$EMU_DB"
            URL="https://osf.io/download/pg7sk/"
            curl -L "$URL" -o emu_prebuilt.tar
            tar -xvf emu_prebuilt.tar
            rm emu_prebuilt.tar
        )
    fi

    # Run EMU
    if [[ -f "$EMU_FASTA" && -f "$EMU_TAX" ]]; then
        echo "[$(date +%T)] Running Taxonomy (Emu)..."
        mkdir -p "$OUTDIR/taxonomy"
        emu abundance "$OUTDIR/intermediate/ont_filt.fq.gz" \
                      --db "$EMU_DB" \
                      --threads "$THREADS" \
                      --output-dir "$OUTDIR/taxonomy"

        # Capture the Raw TaxID
        RAW_REPORT=$(ls "$OUTDIR/taxonomy/"*rel-abundance.tsv 2>/dev/null | grep -v "species" | head -n 1)
        if [[ -f "$RAW_REPORT" ]]; then
            TOP_TAXID=$(awk -F'\t' 'NR==2 {print $1}' "$RAW_REPORT")
            RAW_CONF=$(awk -F'\t' 'NR==2 {print $2}' "$RAW_REPORT")
            TOP_CONF=$(awk "BEGIN {printf \"%.2f\", $RAW_CONF * 100}")
        fi
    else
        echo "[!] Error: Emu database files missing after download attempt. Skipping."
    fi
fi
echo ""
echo ""
echo "=============================================================================="
echo "                  De-novo assembly with Flye"
echo "=============================================================================="
echo ""
echo ""
# De Novo Assembly with Flye
flye --nano-hq "$OUTDIR/intermediate/ont_filt.fq.gz" \
     --genome-size "$GSIZE" \
     --threads "$THREADS" \
     --out-dir "$OUTDIR/flye"

echo ""
echo ""
echo "=============================================================================="
echo "           Read-error correction and consensus extraction with Medaka"
echo "=============================================================================="
echo ""
echo ""
# Polishing and error-correction with Medaka
medaka_consensus -i "$OUTDIR/intermediate/ont_filt.fq.gz" -d "$OUTDIR/flye/assembly.fasta" -m "$MEDAKA_MODEL" -t "$THREADS" -o "$OUTDIR/medaka"
M_STATS_FILE="$OUTDIR/medaka/consensus.fasta"
M_STATS=$(awk '/^>/ {if (seqlen){print seqlen}; seqlen=0; next} {seqlen += length($0)} END {print seqlen}' "$M_STATS_FILE" | sort -rn | awk '{a[i++]=$1; s+=$1} END {if(s==0){print "0 0 0 0"} else {for(j=0;j<i;j++){t+=a[j]; if(t>=s/2){print s,i,a[j],j+1; break}}}}')
read -r M_LEN M_CNT M_N50 M_L50 <<< "${M_STATS:-0 0 0 0}"

echo ""
echo ""
echo "=============================================================================="
echo "              Performing Long-read filtering using Polypolish"
echo "=============================================================================="
echo ""
echo ""

# Hybrid Polishing with Polypolish [Only in hybrid-mode]
echo "=============================================================================="
echo "              Performing Hybrid Polishing using Polypolish"
echo "=============================================================================="

# Hybrid Polishing with Polypolish [Only in hybrid-mode]
if [[ -n "$R1" && -n "$R2" ]]; then
    
    # Align Short Reads
    bwa index "$OUTDIR/medaka/consensus.fasta" > /dev/null 2>&1
    bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R1.fq.gz" > "$OUTDIR/intermediate/1.sam"
    bwa mem -t "$THREADS" "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/sh_R2.fq.gz" > "$OUTDIR/intermediate/2.sam"
    
    # Generate Mapping Rate for the report
    samtools flagstat "$OUTDIR/intermediate/1.sam" > "$OUTDIR/logs/bwa_flagstat.txt"
    BWA_MAPPING_RATE=$(awk -F'[()]' '/mapped / {print $2}' "$OUTDIR/logs/bwa_flagstat.txt" | head -n 1 | awk '{print $1}' | tr -d '%')

    # Filter and Polish
    polypolish filter --in1 "$OUTDIR/intermediate/1.sam" --in2 "$OUTDIR/intermediate/2.sam" \
                      --out1 "$OUTDIR/intermediate/f1.sam" --out2 "$OUTDIR/intermediate/f2.sam"
    
    POLY_LOG="$OUTDIR/logs/polypolish.log"
    polypolish polish "$OUTDIR/medaka/consensus.fasta" "$OUTDIR/intermediate/f1.sam" "$OUTDIR/intermediate/f2.sam" \
                  > "$FINAL_ASM" 2> "$POLY_LOG"

    # Scrape variables 
    MEAN_DEPTH=$(grep "mean read depth:" "$POLY_LOG" | awk '{print $4}')
    POS_CHANGED=$(grep "positions changed" "$POLY_LOG" | awk '{print $1}')
    # Grabs the percentage (e.g., 99.9257%)
    EST_ACC=$(grep "estimated pre-polishing sequence accuracy:" "$POLY_LOG" | awk '{print $5}')
    # Grabs the Q-score (e.g., Q31.29)
    Q_VAL=$(grep "estimated pre-polishing" "$POLY_LOG" | awk -F'[()]' '{print $2}')
else
    # ONT-Only Mode: Explicitly bind all variables to prevent 'unbound variable' errors
    echo "[$(date +%T)] 5/7: Short reads not provided. Skipping Hybrid Polishing."
    cp "$OUTDIR/medaka/consensus.fasta" "$FINAL_ASM"
    
    BWA_MAPPING_RATE="N/A"
    MEAN_DEPTH="N/A"
    POS_CHANGED="0"
    EST_ACC="N/A"
    Q_VAL="N/A"
fi

echo ""
echo ""
echo "=============================================================================="
echo "                  Functional annotation with PROKKA"
echo "=============================================================================="
echo ""
echo ""
# Functional annotation with Prokka
set +e
mkdir -p "$OUTDIR/annotation"

# Fix for Prokka/tbl2asn error on newer systems
echo -e '#!/bin/bash\necho "tbl2asn 25.8"' > "$OUTDIR/intermediate/tbl2asn"
chmod +x "$OUTDIR/intermediate/tbl2asn"

PROKKA_CMD="PATH=\"$OUTDIR/intermediate:\$PATH\" prokka --outdir \"$OUTDIR/annotation\" --coverage $PROKKA_COV --evalue $PROKKA_EVAL --prefix mostar_Annotation --cpus \"$THREADS\" --kingdom Bacteria --force"
[[ -n "$PROT_REF" ]] && PROKKA_CMD="$PROKKA_CMD --proteins \"$PROT_REF\""

if eval "$PROKKA_CMD \"$FINAL_ASM\"" > "$OUTDIR/logs/prokka.log" 2>&1; then
    PROKKA_SUCCESS=true
    echo "[$(date +%T)] Prokka completed successfully."
else
    PROKKA_SUCCESS=false
    echo "[!] WARNING: Prokka failed. Proceeding with limited AMR detection."
fi
set -e

echo ""
echo ""
echo "=============================================================================="
echo "              AMR-resistance profile with NCBI-AMRFinder+"
echo "=============================================================================="
echo ""
echo ""

# AMR Profiling with NCBI AMRFinder+
echo "[$(date +%T)] 7/7: AMR Gene Detection... will use fasta if PROKKA failed/didnt run"
if ! amrfinder --database_version > /dev/null 2>&1; then amrfinder -u; fi

AMR_BASE="amrfinder --threads $THREADS --plus"
[[ -n "$ORGANISM" ]] && AMR_BASE="$AMR_BASE -O $ORGANISM"

if [ "$PROKKA_SUCCESS" = true ]; then
    eval "$AMR_BASE -n \"$FINAL_ASM\" -p \"$OUTDIR/annotation/mostar_Annotation.faa\" -g \"$OUTDIR/annotation/mostar_Annotation.gff\" > \"$OUTDIR/amr_results/AMR_Report.tsv\""
else
    eval "$AMR_BASE -n \"$FINAL_ASM\" > \"$OUTDIR/amr_results/AMR_Report.tsv\""
fi

echo ""
echo ""
echo "=============================================================================="
echo "                  Cleaning up and deleting intermediate files"
echo "=============================================================================="
echo ""
echo ""

# Cleanup
[[ "${CLEANUP}" == "true" ]] && rm -f "$OUTDIR/intermediate/"*.sam "$OUTDIR/intermediate/ont_filt.fq.gz"

METRICS=$(awk '/^>/ {if (seqlen){print seqlen}; seqlen=0; next} {seqlen += length($0)} END {print seqlen}' "$FINAL_ASM" | sort -rn | \
awk '{a[i++]=$1; sum+=$1} END {if (sum==0) {print "0 0 0 0"; exit}; for(j=0;j<i;j++){total+=a[j]; if(total>=sum/2){print sum,i,a[j],j+1; break}}}')
read -r TOTAL_LEN CONTIG_CNT N50_VAL L50_VAL <<< "${METRICS:-0 0 0 0}"

if [[ "${CLEANUP}" == "true" ]]; then
    echo "[$(date +%T)] Cleaning up intermediate files..."
    rm -f "$OUTDIR/intermediate/"*.sam
    rm -f "$OUTDIR/intermediate/ont_filt.fq" # Ensure uncompressed filt is removed
fi
echo ""
echo ""
echo "=============================================================================="
echo "                      MOSTAR-ASM Pipeline complete!"
echo "=============================================================================="
echo ""
echo ""
echo "=================================================================================="
echo "=================================================================================="
printf "%-15s %-20s %-20s\n" "METRIC" "MEDAKA (ONT)" "FINAL (POLISHED)"
echo "--------------------------------------------------------"
printf "%-15s %-20s %-20s\n" "Total Length" "${M_LEN:-0} bp" "${TOTAL_LEN:-0} bp"
printf "%-15s %-20s %-20s\n" "Contig Count" "${M_CNT:-0}" "${CONTIG_CNT:-0}"
printf "%-15s %-20s %-20s\n" "N50" "${M_N50:-0} bp" "${N50_VAL:-0} bp"
echo "--------------------------------------------------------"

# Generate report using all captured variables
generate_html_report

echo "================================================================================="
echo "    MOSTAR Pipeline complete! Final Report: $OUTDIR/MOSTAR_Final_Report.html"
echo ""
echo "              If you found this pipeline useful, please cite!"
echo ""
echo "                         | Nermin Zecic, 2026 |"
echo "================================================================================="
echo ""
echo ""
