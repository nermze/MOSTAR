#!/usr/bin/env bash
set -euo pipefail
trap 'echo "[ERROR] Pipeline failed at line $LINENO"; exit 1' ERR
START_TIME=$(date +%s)

VERSION="1.0.0"


# MOSTAR is a comprehensive bioinformatics pipeline for proceccsing ONT-reads.
# * Hybrid-assembly
# * Ont-Only assembly
# * Polishing
# * Functional annotaiton
# * AMR profiling
# * Taxonomic profiling
# * Built-in Quality controls
# * HTML report generation with all the stats and results

# Help Menu
usage() {
    echo ""
    echo "A comprehensive bioinformatics pipeline by Nermin Zecic, <nermze@gmail.com>"
    echo ""
    echo "      __      __   __    ____  _______   __     _____             "
    echo "      | |\  /| |  /  \  / ___| |_   _|  /  \   | __  \            "
    echo "      | | \/ | | | || | \___ \   | |   / /\ \  | |_) /            "
    echo "      |_|\__/|_|  \__/  |____/   |_|  /_/  \_\ |_\ \_\            "
    echo ""
    echo ""
    echo "     Assembly, Polishing, Annotation & AMR of ONT reads (v1.0.0)"
    echo ""
    echo "      Tip: MOSTAR can perform both hybrid and regular assembly"
    echo ""
    echo "Hybrid mode: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism] -1 R1.fq -2 R2.fq"
    echo "ONT-only: mostar -n ont.fq.gz -g [size] -o [dir] -p [Organism]"
    echo ""
    echo "Required:"
    echo "  --ont           ONT Long reads (.fastq.gz)"
    echo "  --genome-size   Genome size (e.g., 2.1m, 5.0m, 4g)"
    echo "  --output        Output directory"
    echo "  --medaka        Medaka model (Default: r1041_e82_400bps_sup_v5.2.0)"
    echo ""
    echo "Options:"
    echo "  --r1/--r2       Illumina R1/R2 (Enables Hybrid mode)"
    echo "  --organism      Organism for AMRFinder+ (e.g., Escherichia, Staphylococcus)"
    echo "  --filtlong-cov  Filtlong target coverage (Default: 100)"
    echo ""
    echo "Annotation options:"
    echo "  --bakta-db      BAKTA database path, enables annotation"
    echo "  --bakta-ref     BAKTA annotation reference (GFF)"
    echo "  --complete      BAKTA enable if all sequences are complete (circular) [Default: disabled]"
    echo ""
    echo "Classification options:"
    echo "  --kraken-db     Requires pre-built Kraken2 database"
    echo "  --confidence    Kraken2 confidence threshold (Default: 0.1)"
    echo "  --emu-db        Requires EMU database path, will auto-download (16s Amplicon classifier)"
    echo ""
    echo "Other options:"
    echo "  --cleanup       Cleanup intermediate files"
    echo "  --threads       CPU threads (Default: 10)"
    echo ""
    echo MOSTAR v1.0.0
    exit 1
}

# Generate a HTML-report 
generate_html_report() {
    local HTML_OUT="$OUTDIR/MOSTAR_Final_Report.html"
    local AMR_FILE="$OUTDIR/amr_results/AMR_Report.tsv"
    local EMU_REPORT="$OUTDIR/taxonomy/emu_results_rel-abundance.tsv"
    local TOP_TAXID="N/A"
    local TOP_ABUNDANCE="0.00"
    local END_TIME=$(date +%s)
    local DURATION=$(( (END_TIME - START_TIME) / 60 ))

    # Extract top taxid and abundance from EMU report
    if [[ -s "$EMU_REPORT" ]]; then
        local RAW_DATA
        RAW_DATA=$(LC_NUMERIC=C awk -F'\t' "NR==2 {printf \"%s|%.2f\", \$1, \$2*100}" "$EMU_REPORT" || echo "N/A|0.00")
        TOP_TAXID=$(echo "$RAW_DATA" | cut -d'|' -f1)
        TOP_ABUNDANCE=$(echo "$RAW_DATA" | cut -d'|' -f2)
    fi

    [[ -z "$TOP_ABUNDANCE" ]] && TOP_ABUNDANCE="0.00"
    [[ -z "$TOP_TAXID" ]] && TOP_TAXID="N/A"

    # TaxID display (link or N/A)
    local TAXID_DISPLAY
    if [[ "$TOP_TAXID" != "N/A" ]]; then
        TAXID_DISPLAY="<a href='https://www.ncbi.nlm.nih.gov/datasets/taxonomy/tree/?taxon=${TOP_TAXID}'
           target='_blank' style='color:var(--accent); text-decoration:none; border-bottom:1px dashed var(--accent);'>
           ${TOP_TAXID} &#128279;</a>"
    else
        TAXID_DISPLAY="<span style='color:#95a5a6;'>N/A</span>"
    fi

    # Taxonomic classification cards (Kraken2 if available)
    local KRAKEN_CARDS=""
    if [[ "$RUN_KRAKEN2" == true ]]; then
        KRAKEN_CARDS="
        <div class='qc-card'>
            <span class='qc-label'>Kraken2 Species</span>
            <span class='qc-val'>${K2_SPECIES:-N/A}</span>
        </div>
        <div class='qc-card'>
            <span class='qc-label'>Kraken2 Confidence</span>
            <span class='qc-val'>${K2_ABUNDANCE:-0.00}%</span>
        </div>"
    fi

    # Assembly table header — 3-column if hybrid, 2-column if ONT-only
    local TABLE_HEADER
    local COL_WIDTHS_ASSEMBLY
    if [[ -n "${R1:-}" ]]; then
        TABLE_HEADER="<tr><th>Metric</th><th>Initial (ONT)</th><th>Final (Hybrid)</th></tr>"
        COL_WIDTHS_ASSEMBLY="<col style='width:40%'><col style='width:30%'><col style='width:30%'>"
    else
        TABLE_HEADER="<tr><th>Metric</th><th>Assembly Stats</th></tr>"
        COL_WIDTHS_ASSEMBLY="<col style='width:40%'><col style='width:60%'>"
    fi

    # Assembly table rows
    get_row() {
        local LABEL=$1 OLD=$2 NEW=$3
        if [[ -n "${R1:-}" ]]; then
            echo "<tr><td class='metric-name'>$LABEL</td><td>${OLD}</td><td class='val-new'>${NEW}</td></tr>"
        else
            echo "<tr><td class='metric-name'>$LABEL</td><td class='val-new'>${OLD}</td></tr>"
        fi
    }
    local ROW_LEN ROW_CNT ROW_N50
    ROW_LEN=$(get_row "Total Genome Length" "${M_LEN:-0} bp"     "${TOTAL_LEN:-0} bp")
    ROW_CNT=$(get_row "Contig Count"        "${M_CNT:-0}"        "${CONTIG_CNT:-0}")
    ROW_N50=$(get_row "N50 Score"           "${M_N50:-0} bp"     "${TOTAL_LEN:-0} bp")

    # Hybrid-only QC cards
    local HYBRID_METRICS=""
    if [[ -n "${R1:-}" ]]; then
        local GAP_CLASS=""
        [[ "${ZERO_DEPTH_BP:-0}" != "0" ]] && GAP_CLASS="gap-alert"
        HYBRID_METRICS="
        <div class='qc-card'><span class='qc-label'>Short-Read Depth</span><span class='qccatval'>${MEAN_DEPTH:-0}x</span></div>
        <div class='qc-card'><span class='qc-label'>Polished Bases</span><span class='qc-val'>${POS_CHANGED:-0} bp</span></div>
        <div class='qc-card ${GAP_CLASS}'><span class='qc-label'>Zero-Depth Gaps</span><span class='qc-val'>${ZERO_DEPTH_BP:-0} bp</span></div>"
    fi

    # AMR table rows
    if [[ -s "$AMR_FILE" ]]; then
        AMR_ROWS=$(tail -n +2 "$AMR_FILE" | sort -t$'\t' -k17,17nr | awk -F'\t' '{
            val = $17 + 0;
            if (val >= 100) color="#27ae60";
            else if (val >= 90) color="#3498db";
            else color="#e67e22";
            printf "<tr>"
            printf "<td><span class=\"amr-tag\" style=\"background:%s15; color:%s; border-color:%s40;\">%s</span></td>", color, color, color, $6
            printf "<td><small>%s</small></td>", $11
            printf "<td><div class=\"identity-bar\">"
            printf "<div class=\"identity-fill\" style=\"width:%.2f%%; background-color:%s;\"></div>", val, color
            printf "<span style=\"color:%s; font-weight:bold;\">%.2f%%</span>", color, val
            printf "</div></td>"
            printf "</tr>\n"
